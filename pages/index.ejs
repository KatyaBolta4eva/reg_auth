<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title><%= title %></title>
    <script src="https://unpkg.com/imask"></script>
</head>
<body>

<%- include('./partials/guest-header') %>

<% if (created) {%>
    <div class="alert alert-success" id="success-alert">
        Заявка успешно отправлена!
    </div>

<% } %>

<% if (error) {%>
    <div class="alert alert-danger" id="error-alert">
        Что-то пошло не так!
    </div>

<% } %>

<div class="container mt-4">
    <h1><%= title %></h1>

    <form action="/" method="post" class="mb-2" id="appointment-form">
        <div class="form-group mb-2">
            <input type="text" class="form-control" name="fio" placeholder="ФИО"
                   pattern="[А-Яа-яЁёA-Za-z\s\-]+"
                   minlength="2"
                   maxlength="100"
                   title="ФИО должно содержать только буквы, пробелы и дефис (минимум 2 символа)"
                   required>
        </div>
        <div class="form-group mb-2">
            <input type="tel" class="form-control" name="phone" placeholder="+7 (___) ___-__-__"
                   minlength="16"
                   maxlength="18"
                   required>
        </div>
        <div class="form-group mb-2">
            <textarea class="form-control" name="problem" placeholder="Опишите вашу проблему"
                      minlength="3"
                      maxlength="500"
                      rows="4"
                      title="Описание проблемы должно содержать минимум 10 символов"
                      required></textarea>
        </div>

        <button type="submit" class="btn btn-primary" id="submit-btn">Отправить</button>
    </form>
</div>

<script src="/app.js"></script>

</body>
</html>