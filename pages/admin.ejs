<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title><%= title %></title>
</head>
<body>

<%- include('./partials/user-header') %>

<div class="container mt-4">
    <h1><%= title %></h1>
    <p class="text-muted">Текущий оператор: <%= userEmail %></p>

    <% if (notes.length) {%>
    <div class="card">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>ФИО</th>
                    <th>Телефон</th>
                    <th>Проблема</th>
                </tr>
            </thead>
            <tbody>
            <% for (let i = 0; i < notes.length; i++) { %>
                <tr>
                    <td><%= new Date(notes[i].createdAt).toLocaleString('ru-RU') %></td>
                    <td><%= notes[i].fio %></td>
                    <td><%= notes[i].phone %></td>
                    <td><%= notes[i].problem %></td>
                </tr>
            <% } %>
            </tbody>
        </table>
    </div>
    <% } else {%>
    <p>Нет заявок!</p>
    <% } %>
</div>
</body>
</html>